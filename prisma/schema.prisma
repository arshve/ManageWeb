generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  SUPER_ADMIN
  ADMIN
  SALES
  MANAGE
  DRIVER
}

enum CashflowType {
  PENGELUARAN
  PEMASUKAN
}

model Cashflow {
  id        String       @id @default(cuid())
  type      CashflowType
  name      String
  amount    Float
  category  String?
  createdAt DateTime     @default(now())

  @@index([createdAt])
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  ON_DELIVERY
  DELIVERED
  FAILED
}

enum AnimalType {
  KAMBING
  DOMBA
  SAPI
}

enum AnimalGrade {
  SUPER
  A
  B
  C
  D
}

enum AnimalCondition {
  SEHAT
  MATI
  SAKIT
}

enum EntryStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EntryEditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  BELUM_BAYAR
  DP
  LUNAS
}

enum Pengiriman {
  HARI_H
  H_1
  H_2
  H_3
  H_PLUS_1
  H_PLUS_2
  H_PLUS_3
  TITIP_POTONG
}

model Profile {
  id             String               @id @default(cuid())
  username       String               @unique
  password       String
  name           String
  role           Role                 @default(SALES)
  phone          String?
  rekBank        String?
  isActive       Boolean              @default(true)
  entries        Entry[]
  vehiclePlate   String?
  lastLat        Float?
  lastLng        Float?
  lastLocationAt DateTime?
  deliveries     Delivery[]
  availability   DriverAvailability[]
  proposedEdits  EntryEditRequest[]   @relation("EditRequestProposer")
  reviewedEdits  EntryEditRequest[]   @relation("EditRequestReviewer")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([role, isActive])
}

model Livestock {
  id        String          @id @default(cuid())
  sku       String          @unique
  type      AnimalType
  grade     AnimalGrade?
  condition AnimalCondition @default(SEHAT)
  weightMin Float?
  weightMax Float?
  hargaJual Float?
  hargaModal Float?
  tag       String?
  photoUrl  String?
  notes     String?
  isSold    Boolean         @default(false)
  entryItem EntryItem?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([isSold, condition])
}

model Entry {
  id            String         @id @default(cuid())
  invoiceNo     String         @unique
  status        EntryStatus    @default(PENDING)
  items         EntryItem[]
  requests      EntryRequest[]
  salesId       String
  sales         Profile       @relation(fields: [salesId], references: [id])
  dp            Float?
  totalBayar    Float?
  paymentStatus PaymentStatus @default(BELUM_BAYAR)
  buyerName     String
  buyerPhone    String?
  buyerAddress  String?
  buyerMaps     String?
  buyerLat      Float?
  buyerLng      Float?
  pengiriman    Pengiriman?
  notes         String?
  buktiTransfer String[]      @default([])
  isSent        Boolean       @default(false)
  approvedAt    DateTime?
  approvedBy    String?
  deliveryDate  DateTime?     @db.Date
  delivery      Delivery?
  editRequests          EntryEditRequest[]
  deleteRequestedAt     DateTime?
  deleteRequestedById   String?
  sortAt                DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([deliveryDate])
  @@index([sortAt])
  @@index([status, deliveryDate])
  @@index([salesId, sortAt])
}

model EntryItem {
  id          String    @id @default(cuid())
  entryId     String
  entry       Entry     @relation(fields: [entryId], references: [id], onDelete: Cascade)
  livestockId String    @unique
  livestock   Livestock @relation(fields: [livestockId], references: [id])
  hargaJual   Float
  hargaModal  Float?
  resellerCut Float?
  hpp         Float?
  profit      Float?
  loadedAt    DateTime?
  loadedBy    String?
  createdAt   DateTime  @default(now())

  @@index([entryId])
}

model EntryRequest {
  id          String       @id @default(cuid())
  entryId     String
  entry       Entry        @relation(fields: [entryId], references: [id], onDelete: Cascade)
  type        AnimalType
  grade       AnimalGrade?
  weightMin   Float?
  weightMax   Float?
  hargaJual   Float
  hargaModal  Float?
  resellerCut Float?
  notes       String?
  isFulfilled Boolean      @default(false)
  createdAt   DateTime     @default(now())

  @@index([entryId])
  @@index([type, grade])
}

model EntryEditRequest {
  id           String                 @id @default(cuid())
  entryId      String
  entry        Entry                  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  proposedById String
  proposedBy   Profile                @relation("EditRequestProposer", fields: [proposedById], references: [id])
  status       EntryEditRequestStatus @default(PENDING)
  itemChanges  Json
  reviewedById String?
  reviewedBy   Profile?               @relation("EditRequestReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([entryId, status])
}

model Delivery {
  id          String         @id @default(cuid())
  entryId     String         @unique
  entry       Entry          @relation(fields: [entryId], references: [id], onDelete: Cascade)
  driverId    String?
  driver      Profile?       @relation(fields: [driverId], references: [id])
  sequence    Int?
  status      DeliveryStatus @default(PENDING)
  deliveredAt   DateTime?
  notes         String?
  proofPhotoUrl String?
  createdAt     DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([driverId, sequence])
  @@index([status])
}

model DriverAvailability {
  id        String   @id @default(cuid())
  driverId  String
  driver    Profile  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([driverId, date])
  @@index([date])
}

model GeocodeCache {
  id        String   @id @default(cuid())
  key       String   @unique
  lat       Float
  lng       Float
  source    String
  hitCount  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model Pricing {
  id         String      @id @default(cuid())
  animalType AnimalType
  grade      AnimalGrade
  hargaBeli  Float
  hargaJual  Float
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([animalType, grade])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  actorId   String?
  actorName String
  action    AuditAction
  entity    String
  entityId  String
  label     String?
  before    Json?
  after     Json?

  @@index([createdAt])
  @@index([entity, createdAt])
  @@index([actorId])
}

/// Singleton white-label configuration. Exactly one row, id = "singleton".
/// All fields nullable so an unconfigured install falls back to code defaults
/// (see src/lib/config/get-config.ts which merges this over COMPANY + metadata).
model AppConfig {
  id              String   @id @default("singleton")
  // Short display name for app chrome (sidebar, login) — kept separate from the
  // long legal companyName so the brand text doesn't balloon in the UI.
  brandName       String?
  // Company / legal
  companyName     String?
  tagline         String?
  address         String?
  city            String?
  bankName        String?
  bankAccountName String?
  bankAccountNo   String?
  signer          String?
  instagram       String?
  // App metadata / SEO
  appTitle        String?
  appDescription  String?
  // Brand assets (Supabase Storage URLs; null → local /public fallback)
  logoUrl         String?
  logoLightUrl    String?
  signatureUrl    String?
  // Theme — brandHex is source of truth; brandScale holds the 11 generated
  // OKLCH stops { "50": "...", ..., "950": "..." }; coverColor overrides the
  // report cover ink.
  brandHex        String?
  brandScale      Json?
  coverColor      String?
  // Landing-page hero carousel: array of { url, alt }. null → built-in default.
  carouselSlides  Json?
  updatedAt       DateTime @updatedAt
}
