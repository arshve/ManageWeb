generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  SALES
  MANAGE
  DRIVER
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  ON_DELIVERY
  DELIVERED
  FAILED
}

enum AnimalType {
  KAMBING
  DOMBA
  SAPI
}

enum AnimalGrade {
  SUPER
  A
  B
  C
  D
}

enum AnimalCondition {
  SEHAT
  MATI
  SAKIT
}

enum EntryStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  BELUM_BAYAR
  DP
  LUNAS
}

model Profile {
  id             String               @id @default(cuid())
  username       String               @unique
  password       String
  name           String
  role           Role                 @default(SALES)
  phone          String?
  isActive       Boolean              @default(true)
  entries        Entry[]
  vehiclePlate   String?
  lastLat        Float?
  lastLng        Float?
  lastLocationAt DateTime?
  deliveries     Delivery[]
  availability   DriverAvailability[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model Livestock {
  id        String          @id @default(cuid())
  sku       String          @unique
  type      AnimalType
  grade     AnimalGrade?
  condition AnimalCondition @default(SEHAT)
  weightMin Float?
  weightMax Float?
  hargaJual Float?
  tag       String?
  photoUrl  String?
  notes     String?
  isSold    Boolean         @default(false)
  entry     Entry?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Entry {
  id            String        @id @default(cuid())
  invoiceNo     String        @unique
  status        EntryStatus   @default(PENDING)
  livestockId   String        @unique
  livestock     Livestock     @relation(fields: [livestockId], references: [id])
  salesId       String
  sales         Profile       @relation(fields: [salesId], references: [id])
  hargaJual     Float
  hargaModal    Float?
  resellerCut   Float?
  hpp           Float?
  profit        Float?
  dp            Float?
  totalBayar    Float?
  paymentStatus PaymentStatus @default(BELUM_BAYAR)
  buyerName     String
  buyerPhone    String?
  buyerWa       String?
  buyerAddress  String?
  buyerMaps     String?
  buyerLat      Float?
  buyerLng      Float?
  notes         String?
  buktiTransfer String[]      @default([])
  isSent        Boolean       @default(false)
  approvedAt    DateTime?
  approvedBy    String?
  deliveryDate  DateTime?     @db.Date
  delivery      Delivery?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([deliveryDate])
}

model Delivery {
  id          String         @id @default(cuid())
  entryId     String         @unique
  entry       Entry          @relation(fields: [entryId], references: [id], onDelete: Cascade)
  driverId    String?
  driver      Profile?       @relation(fields: [driverId], references: [id])
  sequence    Int?
  status      DeliveryStatus @default(PENDING)
  deliveredAt DateTime?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([driverId, sequence])
  @@index([status])
}

model DriverAvailability {
  id        String   @id @default(cuid())
  driverId  String
  driver    Profile  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([driverId, date])
  @@index([date])
}

model GeocodeCache {
  id        String   @id @default(cuid())
  key       String   @unique
  lat       Float
  lng       Float
  source    String
  hitCount  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model Pricing {
  id         String      @id @default(cuid())
  animalType AnimalType
  grade      AnimalGrade
  hargaBeli  Float
  hargaJual  Float
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([animalType, grade])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  actorId   String?
  actorName String
  action    AuditAction
  entity    String
  entityId  String
  label     String?
  before    Json?
  after     Json?

  @@index([createdAt])
  @@index([entity, createdAt])
  @@index([actorId])
}
